location      = "eastus2"
search_location = "eastus"
workload_name = "foundryref"
environment   = "prod"

vnet_address_space = "192.168.0.0/16"

gpt_model = {
  name     = "gpt-4o"
  version  = "2024-11-20"
  sku_name = "GlobalStandard"
  capacity = 50
}

publisher_name  = "Contoso AI Platform"
publisher_email = "platform-team@contoso.example"

# Jumpbox VM settings
jumpbox_admin_username = "azureuser"
jumpbox_admin_password = "REPLACE_WITH_A_STRONG_PASSWORD"

jumpbox_vm_size                     = "Standard_D4s_v5"
jumpbox_license_type                = "Windows_Client"
jumpbox_os_disk_storage_account_type = "Premium_LRS"
jumpbox_os_disk_size_gb             = 127

jumpbox_image_publisher = "microsoftwindowsdesktop"
jumpbox_image_offer     = "windows-11"
jumpbox_image_sku       = "win11-25h2-ent"
jumpbox_image_version   = "latest"

tags = {
  workload   = "microsoft-foundry-baseline"
  iac        = "terraform"
  costcenter = "ai-platform"
}
