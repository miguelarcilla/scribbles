# Microsoft Foundry-hosted Azure OpenAI deployment settings
# Use ONE of the two options below:

# Option 1: Direct Foundry endpoint (default)
AZURE_OPENAI_ENDPOINT=https://{YOUR_AOAI_OR_FOUNDRY_ENDPOINT}.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-5.4
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Option 2: API Management gateway (uncomment to use instead of direct Foundry endpoint)
# When AZURE_APIM_ENDPOINT is set, it takes precedence over AZURE_OPENAI_ENDPOINT
# AZURE_APIM_ENDPOINT=https://{YOUR_APIM_INSTANCE_NAME}.azure-api.net/foundry
# AZURE_APIM_SUBSCRIPTION_KEY=your-subscription-key-here
# ^ If SUBSCRIPTION_KEY is empty, uses DefaultAzureCredential with managed identity

# Optional: tune assistant behavior
SYSTEM_PROMPT=You are a helpful assistant.

# Local dev server port
PORT=50505
