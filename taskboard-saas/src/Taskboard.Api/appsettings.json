{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "common",
    "ClientId": "<API_CLIENT_ID>",
    "Audience": "api://<API_CLIENT_ID>"
  },
  "CosmosDb": {
    "ConnectionString": "<COSMOS_CONNECTION_STRING>",
    "DatabaseName": "taskboard"
  },
  "AllowedOrigins": [
    "https://localhost:5173",
    "https://<STATIC_WEB_APP_HOSTNAME>"
  ]
}
